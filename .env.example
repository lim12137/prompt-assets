# GHCR owner, must match the owner used in .github/workflows/publish-images.yml
GHCR_OWNER=your-github-owner

# Image tags published by GitHub Actions
WEB_IMAGE_TAG=latest
POSTGRES_IMAGE_TAG=16-alpine

# Runtime ports
WEB_PORT=13000
POSTGRES_PORT=5432

# Database bootstrapping
POSTGRES_DB=prompt_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Web runtime env
APP_BASE_URL=http://localhost:13000
